{
  "name": "FrenchyConciergerie — Prospection Airbnb",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 6
            }
          ]
        }
      },
      "id": "trigger-schedule",
      "name": "Toutes les 6h",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "url": "https://www.airbnb.fr/s/Montpellier--France/homes",
        "options": {
          "response": {
            "response": {
              "responseFormat": "text"
            }
          }
        }
      },
      "id": "scrape-airbnb-search",
      "name": "1. Scraper recherche Airbnb",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 0],
      "notes": "ADAPTER L'URL : changer la ville, les filtres, le nombre de guests, etc.\nAlternative : utiliser le node 'HTML Extract' ou Puppeteer community node pour du scraping JS."
    },
    {
      "parameters": {
        "jsCode": "// Extraire les listings Airbnb depuis le HTML\n// NOTE : Airbnb charge les donnees en JSON dans un script tag\n// Ce code est un template — adapter selon la structure actuelle d'Airbnb\n\nconst html = $input.first().json.data || $input.first().json.body || '';\nconst listings = [];\n\n// Methode 1 : Extraire depuis les donnees JSON embarquees\ntry {\n  const jsonMatch = html.match(/\"searchResults\"\\s*:\\s*\\[([\\s\\S]*?)\\]/);\n  if (jsonMatch) {\n    // Parser les resultats\n  }\n} catch(e) {}\n\n// Methode 2 : Regex sur les liens /rooms/ID\nconst roomRegex = /\\/rooms\\/(\\d+)/g;\nlet match;\nconst seenIds = new Set();\nwhile ((match = roomRegex.exec(html)) !== null) {\n  if (!seenIds.has(match[1])) {\n    seenIds.add(match[1]);\n    listings.push({\n      airbnb_id: match[1],\n      url: `https://www.airbnb.fr/rooms/${match[1]}`,\n      ville: 'Montpellier' // ADAPTER\n    });\n  }\n}\n\nreturn listings.map(l => ({ json: l }));"
      },
      "id": "extract-listings",
      "name": "2. Extraire les annonces",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 0]
    },
    {
      "parameters": {
        "url": "={{ 'https://www.airbnb.fr/rooms/' + $json.airbnb_id }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "text"
            }
          },
          "timeout": 15000
        }
      },
      "id": "fetch-listing-detail",
      "name": "3. Charger detail annonce",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [660, 0],
      "notes": "Rate limit : ajouter un node Wait (2-5s) avant ce node pour eviter le blocage"
    },
    {
      "parameters": {
        "jsCode": "// Extraire les details d'une annonce Airbnb\nconst html = $input.first().json.data || '';\nconst inputData = $input.first().json;\n\nconst extract = (regex, fallback = null) => {\n  const m = html.match(regex);\n  return m ? m[1] : fallback;\n};\n\n// Nom de l'annonce\nconst nom = extract(/<title>([^<]+)<\\/title>/) || extract(/\"name\"\\s*:\\s*\"([^\"]+)\"/);\n\n// Host / proprietaire\nconst hostName = extract(/\"host\"\\s*:\\s*\\{[^}]*\"name\"\\s*:\\s*\"([^\"]+)\"/) || extract(/Hote[^:]*:\\s*([^<\"]+)/);\nconst hostProfileId = extract(/\\/users\\/show\\/(\\d+)/);\n\n// Capacite, chambres, note\nconst capacite = extract(/(\\d+)\\s*voyageur/);\nconst chambres = extract(/(\\d+)\\s*chambre/);\nconst note = extract(/\"ratingValue\"\\s*:\\s*(\\d+\\.?\\d*)/);\nconst nbAvis = extract(/\"reviewCount\"\\s*:\\s*(\\d+)/);\nconst superhost = /superhost/i.test(html);\n\n// Prix\nconst prix = extract(/\"priceString\"\\s*:\\s*\"(\\d+)/) || extract(/(\\d+)\\s*€\\s*par nuit/);\n\nreturn [{\n  json: {\n    airbnb_id: inputData.airbnb_id,\n    url: inputData.url || `https://www.airbnb.fr/rooms/${inputData.airbnb_id}`,\n    nom: nom,\n    ville: inputData.ville || 'Montpellier',\n    host_name: hostName,\n    host_profile_id: hostProfileId,\n    capacite: capacite ? parseInt(capacite) : null,\n    chambres: chambres ? parseInt(chambres) : null,\n    note_moyenne: note ? parseFloat(note) : null,\n    nb_avis: nbAvis ? parseInt(nbAvis) : null,\n    superhost: superhost,\n    prix_nuit: prix ? parseInt(prix) : null\n  }\n}];"
      },
      "id": "parse-listing-detail",
      "name": "4. Parser les details",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 0]
    },
