            },
            {
              "name": "url",
              "value": "={{ $json.url }}"
            },
            {
              "name": "ville",
              "value": "={{ $json.ville }}"
            },
            {
              "name": "host_name",
              "value": "={{ $json.host_name }}"
            },
            {
              "name": "host_profile_id",
              "value": "={{ $json.host_profile_id }}"
            },
            {
              "name": "capacite",
              "value": "={{ $json.capacite }}"
            },
            {
              "name": "chambres",
              "value": "={{ $json.chambres }}"
            },
            {
              "name": "note_moyenne",
              "value": "={{ $json.note_moyenne }}"
            },
            {
              "name": "nb_avis",
              "value": "={{ $json.nb_avis }}"
            },
            {
              "name": "superhost",
              "value": "={{ $json.superhost }}"
            }
          ]
        },
        "options": {}
      },
