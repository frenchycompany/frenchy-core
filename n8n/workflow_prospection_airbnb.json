        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"event\": \"sms.send\",\n  \"data\": {\n    \"destinataire\": \"{{ $json.telephone }}\",\n    \"message\": \"Bonjour {{ $json.prenom || $json.nom }}, la conciergerie Frenchy accompagne les proprietaires comme vous dans la gestion locative. Echangeons ? Raphael\"\n  }\n}",
        "options": {}
      },
      "id": "send-sms-relance",
      "name": "11. Envoyer SMS relance",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2420, 0],
      "notes": "ATTENTION : ne s'active que si le lead a un telephone.\nAdapter le message selon le contexte."
    },
    {
      "parameters": {
        "jsCode": "// Resume de l'execution\nconst items = $input.all();\nconst summary = {\n  timestamp: new Date().toISOString(),\n  total_processed: items.length,\n  message: `Pipeline prospection termine. ${items.length} action(s) effectuee(s).`\n};\nreturn [{ json: summary }];"
      },
      "id": "summary",
      "name": "12. Resume",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2640, 0]
    }
