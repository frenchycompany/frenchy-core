# Configuration de l'environnement FC-gestion
# Copiez ce fichier en .env et remplissez avec vos valeurs

# Environnement (development, staging, production)
APP_ENV=development
APP_DEBUG=true
APP_NAME="FC-gestion"
APP_URL=https://gestion.frenchyconciergerie.fr

# Base de données principale
DB_HOST=your_database_host
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_CHARSET=utf8mb4

# Base de données de réservations (Raspberry Pi)
REMOTE_DB_HOST=your_remote_host
REMOTE_DB_NAME=your_remote_database
REMOTE_DB_USER=your_remote_user
REMOTE_DB_PASSWORD=your_remote_password

# Sécurité
SESSION_LIFETIME=3600
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_TIME=900

# Upload de fichiers
MAX_UPLOAD_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx
UPLOAD_PATH=uploads

# Email (pour notifications futures)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_password
MAIL_FROM=noreply@frenchyconciergerie.fr

# Cache
CACHE_ENABLED=true
CACHE_DRIVER=file
CACHE_LIFETIME=3600

# Logs
LOG_LEVEL=info
LOG_PATH=logs
