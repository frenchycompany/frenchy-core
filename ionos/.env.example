# Configuration Frenchy Conciergerie
# Copiez ce fichier en .env et renseignez vos valeurs

# Base de données
DB_HOST=localhost
DB_NAME=frenchy_db
DB_USER=root
DB_PASS=

# Sécurité
APP_ENV=development
APP_DEBUG=true
APP_SECRET=change_me_with_random_string

# Email (optionnel - pour SMTP)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# Site
SITE_URL=http://localhost
