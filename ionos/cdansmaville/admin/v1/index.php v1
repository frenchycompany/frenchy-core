<?php
// Activer le rapport d'erreur pour le débogage
error_reporting(E_ALL);
ini_set('display_errors', 1);

// Vérifier si une session est déjà active avant de l'initialiser
if (session_status() === PHP_SESSION_NONE) {
    session_start();
}

// Inclure les fichiers de configuration et de connexion
require_once 'config.php';
require_once '../db/connection.php';

// Vérifier la connexion à la base de données
if (!$conn) {
    die("Erreur de connexion à la base de données.");
}

// Récupérer les statistiques générales
$totalClients = $conn->query("SELECT COUNT(*) AS count FROM clients")->fetch(PDO::FETCH_ASSOC)['count'];
$totalModules = $conn->query("SELECT COUNT(*) AS count FROM modules")->fetch(PDO::FETCH_ASSOC)['count'];
$totalNews = $conn->query("SELECT COUNT(*) AS count FROM news")->fetch(PDO::FETCH_ASSOC)['count'];

// Récupérer les derniers éléments ajoutés
$lastClient = $conn->query("SELECT nom FROM clients ORDER BY id DESC LIMIT 1")->fetch(PDO::FETCH_ASSOC)['nom'] ?? 'Aucun';
$lastModule = $conn->query("SELECT nom FROM modules ORDER BY id DESC LIMIT 1")->fetch(PDO::FETCH_ASSOC)['nom'] ?? 'Aucun';
$lastNews = $conn->query("SELECT titre FROM news ORDER BY id DESC LIMIT 1")->fetch(PDO::FETCH_ASSOC)['titre'] ?? 'Aucune';

// Récupérer les clients sans contenu
$clientsWithoutContent = $conn->query("SELECT COUNT(*) AS count FROM clients WHERE id NOT IN (SELECT DISTINCT client_id FROM client_content)")->fetch(PDO::FETCH_ASSOC)['count'];
?>
