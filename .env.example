# =============================================================================
# Configuration FrenchyConciergerie - Fichier .env
# Copier ce fichier en .env et remplir les valeurs
# =============================================================================

# Application
APP_ENV=production
APP_DEBUG=false

# Base de données unifiée (VPS)
DB_HOST=localhost
DB_NAME=frenchyconciergerie
DB_USER=frenchy_app
DB_PASSWORD=CHANGE_ME
DB_PORT=3306
DB_CHARSET=utf8mb4

# API OpenAI (pour génération messages SMS/WhatsApp)
OPENAI_API_KEY=sk-CHANGE_ME

# SMS Relay (Raspberry Pi avec modem GSM)
SMS_RELAY_ENABLED=true
SMS_RELAY_HOST=127.0.0.1
SMS_RELAY_PORT=3306

# Téléphone admin
ADMIN_PHONE=+33XXXXXXXXX

# Session
SESSION_TIMEOUT=1800
