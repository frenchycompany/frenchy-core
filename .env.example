# =============================================================================
# Configuration FrenchyConciergerie - Fichier .env
# Copier ce fichier en .env et remplir les valeurs
# =============================================================================

# Application
APP_ENV=production
APP_DEBUG=false

# Base de données unifiée (VPS)
DB_HOST=localhost
DB_NAME=frenchyconciergerie
DB_USER=frenchy_app
DB_PASSWORD=CHANGE_ME
DB_PORT=3306
DB_CHARSET=utf8mb4

# API OpenAI (pour génération messages SMS/WhatsApp)
OPENAI_API_KEY=sk-CHANGE_ME

# [OBSOLETE] Les variables RPI_DB_* ne sont plus nécessaires.
# Après migration, les tables SMS/réservations sont dans la base VPS principale.
# Le Raspberry Pi se connecte au VPS en distant via config/config.ini.

# Téléphone admin
ADMIN_PHONE=+33XXXXXXXXX

# Session
SESSION_TIMEOUT=1800

# Secret partagé pour authentifier les appels cron du RPi vers le VPS
# Générer avec : php -r "echo bin2hex(random_bytes(32));"
CRON_SECRET=CHANGE_ME

# Clé de chiffrement maître du coffre-fort numérique (AES-256)
# Générer avec : openssl rand -hex 32
COFFRE_FORT_KEY=CHANGE_ME

# Admin frenchysite
ADMIN_USER=admin
ADMIN_PASS=CHANGE_ME

# API Key (pour n8n et integrations externes)
# Generer avec : php -r "echo bin2hex(random_bytes(32));"
API_KEY=CHANGE_ME

# Credentials Superhote (automatisation Selenium)
SUPERHOTE_EMAIL=CHANGE_ME
SUPERHOTE_PASSWORD=CHANGE_ME
