# =============================================================================
# Configuration FrenchyConciergerie - Fichier .env
# Copier ce fichier en .env et remplir les valeurs
# =============================================================================

# Application
APP_ENV=production
APP_DEBUG=false

# Base de données unifiée (VPS)
DB_HOST=localhost
DB_NAME=frenchyconciergerie
DB_USER=frenchy_app
DB_PASSWORD=CHANGE_ME
DB_PORT=3306
DB_CHARSET=utf8mb4

# API OpenAI (pour génération messages SMS/WhatsApp)
OPENAI_API_KEY=sk-CHANGE_ME

# Base de données Raspberry Pi (SMS via modem GSM)
RPI_DB_HOST=109.219.194.30
RPI_DB_PORT=3306
RPI_DB_NAME=sms_db
RPI_DB_USER=remote
RPI_DB_PASSWORD=CHANGE_ME

# Téléphone admin
ADMIN_PHONE=+33XXXXXXXXX

# Session
SESSION_TIMEOUT=1800
